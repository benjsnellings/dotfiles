#!/bin/zsh
# claude-lb: load-balancing shim for the Claude Code CLI.
#
# Picks whichever bedrock-access profile currently has the FEWEST running claude
# sessions (ties broken by pool order) and execs the real binary pinned to it.
# If AWS_PROFILE / CLAUDE_CODE_AWS_PROFILE is already set, the pin is honored and
# balancing is skipped.
#
# Consumers:
#   - interactive zsh: the claude() function in ~/.zsh/zsh_alias.zsh delegates here
#   - lattice daemon:  ~/.config/systemd/user/lattice-daemon.service puts this
#     script's dir FIRST on PATH, so the daemon's CLI discovery finds it
#
# NOTE: ~/.claude/settings.json must NOT set AWS_PROFILE / CLAUDE_CODE_AWS_PROFILE
# (its env block overrides what we set here). The balancing table goes to stderr
# and only when interactive, so programmatic stdout (stream-json, plugin list)
# stays byte-clean.

# Real binary (native-installer launcher symlink). Overridable for testing.
: ${CLAUDE_LB_REAL:=$HOME/.local/bin/claude}

# Honor an explicit pin; skip balancing entirely.
if [[ -n $CLAUDE_CODE_AWS_PROFILE || -n $AWS_PROFILE ]]; then
  exec "$CLAUDE_LB_REAL" "$@"
fi

typeset -a profiles=(
  bedrock-access-user        # cl1  ("primary")
  bedrock-access-secondary   # cl2
  bedrock-access-tertiary    # cl3
  bedrock-access-quaternary  # cl4
  bedrock-access-quinary     # cl5
)
typeset default_profile=bedrock-access-user
typeset -A counts
typeset p pid prof
for p in "${profiles[@]}"; do counts[$p]=0; done

# Read a process's AWS_PROFILE from its environment. Prefers /proc (Linux);
# falls back to `ps eww` (macOS/BSD), where env is space-joined with argv.
profile_of() {
  local _pid=$1 _prof=''
  if [[ -r /proc/$_pid/environ ]]; then
    _prof=$(tr '\0' '\n' < /proc/$_pid/environ 2>/dev/null | grep -m1 '^AWS_PROFILE=' | cut -d= -f2)
  else
    _prof=$(ps eww -o command= -p "$_pid" 2>/dev/null | tr ' ' '\n' | grep -m1 '^AWS_PROFILE=' | cut -d= -f2)
  fi
  print -r -- "$_prof"
}

# Tally running claude sessions per profile. Skip OURSELVES: this script's
# process is named `claude` too until the exec below replaces it.
for pid in ${(f)"$(pgrep -x claude 2>/dev/null)"}; do
  [[ $pid == $$ ]] && continue
  prof=$(profile_of "$pid")
  [[ -z $prof ]] && prof=$default_profile
  [[ -n ${counts[$prof]+x} ]] && counts[$prof]=$(( counts[$prof] + 1 ))
done

# Pick the least-loaded profile; first in pool order wins ties.
typeset best=${profiles[1]} best_n=${counts[${profiles[1]}]}
for p in "${profiles[@]}"; do
  if (( counts[$p] < best_n )); then best=$p; best_n=${counts[$p]}; fi
done

# Report load (to stderr, only when interactive) so piped/captured output stays clean.
if [[ -t 2 ]]; then
  label() { local l=${1#bedrock-access-}; [[ $l == user ]] && l=primary; print -r -- "$l"; }
  print -r -- "claude: running sessions per profile" >&2
  for p in "${profiles[@]}"; do
    if [[ $p == $best ]]; then
      printf '  %-11s %2d  <- launching here\n' "$(label $p)" "${counts[$p]}" >&2
    else
      printf '  %-11s %2d\n' "$(label $p)" "${counts[$p]}" >&2
    fi
  done
fi

export AWS_PROFILE=$best CLAUDE_CODE_AWS_PROFILE=$best
exec "$CLAUDE_LB_REAL" "$@"
