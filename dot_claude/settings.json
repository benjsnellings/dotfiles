{
  "env": {
    "CLAUDE_CODE_USE_BEDROCK": "true",
    "CLAUDE_CODE_USE_MANTLE": "true",
    "AWS_PROFILE": "bedrock-access-user",
    "AWS_REGION": "us-east-1",
    "CLAUDE_CODE_AWS_PROFILE": "bedrock-access-user",
    "ANTHROPIC_DEFAULT_FABLE_MODEL": "us.anthropic.claude-fable-5[1m]",
    "ANTHROPIC_DEFAULT_FABLE_MODEL_NAME": "Fable 5 (1M)",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "global.anthropic.claude-opus-4-8[1m]",
    "ANTHROPIC_DEFAULT_OPUS_MODEL_NAME": "Opus 4.8 (1M)",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "global.anthropic.claude-sonnet-5[1m]",
    "ANTHROPIC_DEFAULT_SONNET_MODEL_NAME": "Sonnet 5 (1M)",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "global.anthropic.claude-haiku-4-5-20251001-v1:0",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL_NAME": "Haiku 4.5",
    "ENABLE_PROMPT_CACHING_1H": "1",
    "DISABLE_TELEMETRY": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "DISABLE_BUG_COMMAND": "1",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "CLAUDE_CODE_RETRY_WATCHDOG": "1",
    "CLAUDE_CODE_MAX_RETRIES": "15",
    "MAX_THINKING_TOKENS": "63999",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "WebFetch",
      "WebFetch(domain:*)",
      "Read(*)",
      "ReadFile(*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(cat:*)",
      "Bash(git log:*)",
      "Bash(git -P log:*)",
      "Bash(git status:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git -P diff:*)",
      "Bash(git diff:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git -P show:*)",
      "Bash(git stash:*)",
      "Bash(git push -u origin worktree-*)",
      "Bash(git push origin worktree-*)",
      "Bash(brazil-build release)",
      "Bash(ebb)",
      "Bash(pipeline:*)",
      "mcp__builder-mcp__Delegate",
      "mcp__builder-mcp__ReadInternalWebsites",
      "mcp__builder-mcp__InternalSearch",
      "mcp__builder-mcp__SearchAcronymCentral",
      "mcp__builder-mcp__InternalCodeSearch",
      "mcp__builder-mcp__WorkspaceSearch",
      "mcp__builder-mcp__WorkspaceGitDetails",
      "mcp__builder-mcp__MechanicDiscoverTools",
      "mcp__builder-mcp__MechanicDescribeTool",
      "mcp__builder-mcp__ApolloReadActions",
      "mcp__builder-mcp__CheckFilepathForCAZ",
      "mcp__builder-mcp__TaskeiGetTask",
      "mcp__builder-mcp__TaskeiGetRooms",
      "mcp__builder-mcp__TaskeiListTasks",
      "mcp__builder-mcp__ReadRemoteTestRun",
      "mcp__builder-mcp__GetDogmaClassification",
      "mcp__builder-mcp__GetDogmaRecommendations",
      "mcp__builder-mcp__TicketingReadActions",
      "mcp__builder-mcp__OncallReadActions",
      "mcp__builder-mcp__GetPipelinesRelevantToUser",
      "mcp__builder-mcp__GetPipelineHealth",
      "mcp__builder-mcp__GetPipelineDetails",
      "mcp__builder-mcp__GetSasRisks",
      "mcp__builder-mcp__GetSasCampaigns",
      "mcp__builder-mcp__GKAnalyzeVersionSet",
      "mcp__workplace-chat-mcp__search",
      "mcp__workplace-chat-mcp__search_files",
      "mcp__workplace-chat-mcp__lookup_user",
      "mcp__workplace-chat-mcp__batch_get_user_info",
      "mcp__workplace-chat-mcp__batch_get_conversation_history",
      "mcp__workplace-chat-mcp__batch_get_thread_replies",
      "mcp__workplace-chat-mcp__get_conversation_details",
      "mcp__workplace-chat-mcp__get_dm_channel",
      "mcp__workplace-chat-mcp__get_channel_info",
      "mcp__workplace-chat-mcp__resolve_channel",
      "mcp__workplace-chat-mcp__get_channel_sections",
      "mcp__workplace-chat-mcp__get_channel_tabs",
      "mcp__workplace-chat-mcp__get_canvas_content",
      "mcp__workplace-chat-mcp__get_list_content",
      "mcp__workplace-chat-mcp__list_reminders",
      "mcp__workplace-chat-mcp__list_scheduled_messages",
      "mcp__workplace-chat-mcp__download_file_content"
    ],
    "deny": [
      "Bash(pipeline deploy:*)",
      "Bash(git push* --force*)",
      "Bash(git push* -f*)",
      "Bash(git push* --delete*)",
      "Bash(git push* -d*)",
      "Bash(git push*:main*)",
      "Bash(git push*:refs/heads/main*)",
      "Bash(git push* +*)",
      "Bash(git push* main*)",
      "Bash(cdk deploy:*)",
      "Bash(bb cdk deploy:*)"
    ],
    "ask": [],
    "defaultMode": "plan",
    "additionalDirectories": [
      "/tmp",
      "~/.aim/"
    ]
  },
  "model": "opus",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "aim skills inject",
            "timeout": 10000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "TeamCreate|Agent",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/fix-tmux-panes.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/tmux-claude-state.sh clear",
            "timeout": 5000
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt|idle_prompt|elicitation_dialog",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/tmux-claude-state.sh ask",
            "timeout": 5000
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/tmux-claude-state.sh stop",
            "timeout": 5000
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/tmux-claude-state.sh clear",
            "timeout": 5000
          }
        ]
      }
    ],
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/wt-create.sh",
            "timeout": 120000
          }
        ]
      }
    ],
    "WorktreeRemove": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/wt-remove.sh",
            "timeout": 60000
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "feature-dev@claude-plugins-official": true,
    "agent-sdk-dev@claude-plugins-official": false,
    "frontend-design@claude-plugins-official": true,
    "code-review@claude-plugins-official": false,
    "plugin-dev@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": false,
    "explanatory-output-style@claude-plugins-official": true,
    "hookify@claude-plugins-official": false,
    "learning-output-style@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": false,
    "ralph-loop@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": false,
    "smangit@smangings": false,
    "playwright@claude-plugins-official": false,
    "smangings@smangings": true,
    "superpowers@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {},
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "tui": "default",
  "skipDangerousModePermissionPrompt": true,
  "editorMode": "vim",
  "verbose": true,
  "autoCompactEnabled": true,
  "teammateMode": "in-process",
  "teammateDefaultModel": "global.anthropic.claude-opus-4-6-v1[1m]",
  "feedbackSurveyState": {
    "lastShownTime": 1756164689105
  }
}
